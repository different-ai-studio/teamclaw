# ── deploy/self-host environment template ──────────────────────────────
# Copy to .env, set JWT_SECRET + POSTGRES_PASSWORD + domains, then run:
#   ./bootstrap/gen-secrets.sh   (fills ANON_KEY / SERVICE_ROLE_KEY / MQTT_SERVICE_TOKEN)
#   docker compose up -d

# ── core secret (everything derives from this) ─────────────────────────
# Must be >= 32 chars. Used by Supabase + EMQX JWT auth (HS256).
JWT_SECRET=
# Supabase Postgres superuser password.
POSTGRES_PASSWORD=

# ── derived by bootstrap/gen-secrets.sh (leave blank) ──────────────────
ANON_KEY=
SERVICE_ROLE_KEY=
MQTT_SERVICE_TOKEN=
EMQX_JWT_SECRET=
CADDY_GLOBAL_TLS=
CADDY_SITE_TLS=
CADDY_SITE_SCHEME=

# ── system / docker integration ────────────────────────────────────────
# Path to Docker socket; used by Supabase vector log collector.
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

# ── public domains (used by Caddy + client-facing URLs) ────────────────
FC_DOMAIN=api.example.com
SUPABASE_DOMAIN=supabase.example.com
MQTT_DOMAIN=mqtt.example.com
STUDIO_DOMAIN=studio.example.com
EMQX_DASHBOARD_DOMAIN=emqx.example.com

# Public MQTT address delivered to clients (desktop/iOS/web).
# Use the public hostname so clients outside Docker can reach the broker.
# mqtt://  = plaintext 1883 (direct TCP, no Caddy)
# wss://   = WebSocket TLS via Caddy (port 443, path /mqtt)
# Leave empty to fall back to MQTT_BROKER_URL (single-host / dev only).
MQTT_PUBLIC_BROKER_URL=mqtt://mqtt.example.com:1883

# ── Caddy TLS ──────────────────────────────────────────────────────────
# Podman rootless: use 8080/8443 (bootstrap/up.sh sets these automatically).
CADDY_HTTP_PORT=
CADDY_HTTPS_PORT=
# CADDY_TLS_MODE: "acme" (Let's Encrypt, needs real public domains + 80/443),
#                 "internal" (local CA), or "off" (plain http, local only).
CADDY_TLS_MODE=acme
ACME_EMAIL=ops@example.com

# ── FC service ─────────────────────────────────────────────────────────
BACKEND_KIND=supabase
CRON_TRIGGER_SECRET=
# Standalone postgres backend (only with --profile postgres):
#   set BACKEND_KIND=postgres and uncomment:
# DATABASE_URL=postgres://postgres:postgres@postgres:5432/postgres
POSTGRES_BACKEND_PASSWORD=postgres

# ── object storage (external Alibaba OSS; leave blank to disable) ──────
ACCESS_KEY_ID=
ACCESS_KEY_SECRET=
ROLE_ARN=
BUCKET=teamclaw-team
REGION=cn-shenzhen
ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com

# ── LiteLLM AI gateway (bundled; starts with `docker compose up`) ──────
# Runs at http://litellm:4000 in-network and on the host at 127.0.0.1:4000.
# Its state lives in the _litellm database inside the Supabase `db` container
# (created by the litellm-init one-shot) — no separate postgres.
#
# Leave LITELLM_URL blank to use the bundled gateway. Only set it to point FC at
# an EXTERNAL gateway instead; a blank value in .env is fine, but a blank value
# reaching FC directly would make it fall back to the hosted https://ai.ucar.cc.
LITELLM_URL=
# Derived by bootstrap/gen-secrets.sh (leave blank; must start with "sk-").
LITELLM_MASTER_KEY=
# Admin UI login at http://127.0.0.1:4000/ui — password derived by gen-secrets.sh.
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=
# Host loopback port for the gateway/admin UI.
LITELLM_PORT=4000
# Upstream provider keys, referenced by litellm/config.yaml via os.environ/.
# litellm/config.yaml ships a static model_list for DeepSeek (deepseek-v4-flash,
# deepseek-v4-pro) — set DEEPSEEK_API_KEY to enable them. Additional models can
# also be added at runtime in the admin UI (persisted via STORE_MODEL_IN_DB).
# Never commit real keys: this file is a template, .env is gitignored.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── TeamClaw daemon (optional; docker compose --profile daemon) ─────────
# Daemon team-join invite token. Leave blank in the template. After a team
# exists, mint one with ./amuxd/mint-invite.sh and paste the token here, then:
#   docker compose --profile daemon up -d --build amuxd
# (TEAMCLAW_CLOUD_API_URL for the daemon is set in docker-compose.yml to the
#  internal FC service http://fc:9000 — no env var needed.)
AMUXD_JOIN_TOKEN=
# Daemon LLM provider for opencode (OpenAI-compatible). Set these to let the
# daemon actually RUN agent sessions; leave OPENCODE_API_KEY blank for
# presence-only (no agent execution). Point BASE_URL at any OpenAI-compatible
# endpoint (your LiteLLM gateway, OpenAI, etc.).
OPENCODE_BASE_URL=
OPENCODE_API_KEY=
OPENCODE_MODEL=
# Optional cosmetic / provider id (defaults: selfhost / "Self-host LLM"):
OPENCODE_PROVIDER_ID=selfhost
OPENCODE_PROVIDER_NAME=Self-host LLM

# ── Supabase stack (vendored upstream defaults) ─────────────────────────
# These are referenced WITHOUT a fallback in supabase/docker-compose.yml.
# Values below match the canonical upstream Supabase self-host defaults.
# gen-secrets.sh derives the URL vars (SUPABASE_PUBLIC_URL, API_EXTERNAL_URL,
# SITE_URL) from SUPABASE_DOMAIN / FC_DOMAIN above — leave them blank here.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
JWT_EXPIRY=3600
PGRST_DB_SCHEMAS=public,storage,graphql_public,amux
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
FUNCTIONS_VERIFY_JWT=false
IMGPROXY_ENABLE_WEBP_DETECTION=true
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
LOGFLARE_API_KEY=your-logflare-api-key-please-change
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify
ADDITIONAL_REDIRECT_URLS=
# SMTP — placeholder values so GoTrue (auth) starts; it will not actually
# deliver mail until you point these at a real SMTP server. Do NOT blank these:
# GoTrue parses SMTP_PORT as an integer and fails to start on an empty value.
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_SENDER_NAME=fake_sender
# Derived by gen-secrets.sh from SUPABASE_DOMAIN / FC_DOMAIN — leave blank:
SUPABASE_PUBLIC_URL=
API_EXTERNAL_URL=
SITE_URL=
