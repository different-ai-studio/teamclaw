# ── Local development preset (macOS / Podman / Docker Desktop) ───────────
#
# Quick start:
#   cd deploy/self-host
#   cp .env.local.example .env
#   ./bootstrap/gen-secrets.sh
#   ./bootstrap/up.sh
#   ./bootstrap/check.sh
#
# Uses 127.0.0.1 + host ports — do NOT add FC_DOMAIN / MQTT_DOMAIN to /etc/hosts.
# JWT_SECRET + POSTGRES_PASSWORD below are dev-only placeholders; change before
# any shared or production host.
#
# Client (Desktop): cp ../../packages/app/.env.local.example ../../packages/app/.env.local

# ── core secret (gen-secrets.sh validates length) ───────────────────────
JWT_SECRET=local-dev-jwt-secret-do-not-use-in-production-32
POSTGRES_PASSWORD=local-dev-postgres-password

# ── derived by bootstrap/gen-secrets.sh (leave blank) ──────────────────
ANON_KEY=
SERVICE_ROLE_KEY=
MQTT_SERVICE_TOKEN=
EMQX_JWT_SECRET=
CADDY_GLOBAL_TLS=
CADDY_SITE_TLS=
CADDY_SITE_SCHEME=

# ── system / docker integration ────────────────────────────────────────
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

# ── domains (Caddy vhost labels + future server DNS — not /etc/hosts) ─
FC_DOMAIN=api.example.com
SUPABASE_DOMAIN=supabase.example.com
MQTT_DOMAIN=mqtt.example.com
STUDIO_DOMAIN=studio.example.com
EMQX_DASHBOARD_DOMAIN=emqx.example.com

# Delivered to clients via GET /v1/config/bootstrap (Desktop MQTT TCP)
MQTT_PUBLIC_BROKER_URL=mqtt://127.0.0.1:1883

# ── Caddy TLS (local: plain HTTP on mapped ports) ─────────────────────
# Podman rootless: bootstrap/up.sh also sets 8080/8443 when using podman-compose.
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
CADDY_TLS_MODE=off
ACME_EMAIL=ops@example.com

# ── FC service ─────────────────────────────────────────────────────────
BACKEND_KIND=supabase
CRON_TRIGGER_SECRET=

POSTGRES_BACKEND_PASSWORD=postgres

# ── object storage (optional — leave blank to disable OSS features) ───
ACCESS_KEY_ID=
ACCESS_KEY_SECRET=
ROLE_ARN=
BUCKET=teamclaw-team
REGION=cn-shenzhen
ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com

# ── LiteLLM (optional) ─────────────────────────────────────────────────
LITELLM_URL=
LITELLM_MASTER_KEY=

# ── TeamClaw daemon (optional; docker compose --profile daemon) ─────────
AMUXD_JOIN_TOKEN=
OPENCODE_BASE_URL=
OPENCODE_API_KEY=
OPENCODE_MODEL=
OPENCODE_PROVIDER_ID=selfhost
OPENCODE_PROVIDER_NAME=Self-host LLM

# ── Supabase stack ─────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
JWT_EXPIRY=3600
PGRST_DB_SCHEMAS=public,storage,graphql_public,amux
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
# Local: skip email verification (no real SMTP)
ENABLE_EMAIL_AUTOCONFIRM=true
# Local desktop login without SMTP — use「快速试用」on the sign-in screen.
ENABLE_ANONYMOUS_USERS=true
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
FUNCTIONS_VERIFY_JWT=false
IMGPROXY_ENABLE_WEBP_DETECTION=true
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
LOGFLARE_API_KEY=your-logflare-api-key-please-change
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify
ADDITIONAL_REDIRECT_URLS=
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_SENDER_NAME=fake_sender
SUPABASE_PUBLIC_URL=
API_EXTERNAL_URL=
SITE_URL=
