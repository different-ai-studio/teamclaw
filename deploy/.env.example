# ACR (Alibaba Container Registry)
ACR_REGISTRY=registry.cn-shenzhen.aliyuncs.com
ACR_USERNAME=your_acr_username
ACR_PASSWORD=your_acr_password
ACR_IMAGE=registry.cn-shenzhen.aliyuncs.com/teamclaw/teamclaw-seed:latest

# ECS SSH
ECS_HOST=your_ecs_ip
ECS_PORT=22
ECS_USER=root
ECS_PASSWORD=your_ecs_password

# Seed node
SEED_API_KEY=换成一个随机强密码
