# Local client → self-host backend (deploy/self-host on this machine)
#
#   cp .env.local.example .env.local
#   pnpm tauri:dev
#
# Requires deploy/self-host up and ./bootstrap/check.sh passing FC /healthz.
# Do not commit .env.local (gitignored).

# Cloud API — FC direct (recommended for Desktop)
VITE_CLOUD_API_URL=http://127.0.0.1:9000

# ── Web only (pnpm dev) — uncomment if testing in browser ─────────────
# Expose EMQX WS first: deploy/self-host/docker-compose.override.yml with
#   services.emqx.ports: ["8083:8083"]
# VITE_APP_PLATFORM=web
# VITE_MQTT_WS_URL=ws://127.0.0.1:8083/mqtt
