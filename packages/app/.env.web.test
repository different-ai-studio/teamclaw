# Self-host test environment (single ECS, wss-capable).
# Loaded by `vite --mode web.test` (build:web:test / dev:web:test) and by the
# extension build when EXT_ENV=test. Unlike .env.web (localhost http + ws://),
# this targets the real test deployment over HTTPS + wss, so it is valid for a
# `chrome-extension://` secure context.
VITE_APP_PLATFORM=web
VITE_CLOUD_API_URL=https://api.teamclaw-dev.ucar.cc
# Real TLS MQTT-over-WebSocket endpoint — overrides the TCP broker URL from
# /v1/config/bootstrap. wss is required by chrome-extension:// secure context.
VITE_MQTT_WS_URL=wss://mqtt.teamclaw-dev.ucar.cc/mqtt
