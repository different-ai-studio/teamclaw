# Copy this file to .env and fill in real values.
# Then run: source .env && cargo build
# Or use direnv: add "dotenv .env" to daemon/.envrc
#
# DO NOT commit .env — it is gitignored.

# The Cloud API endpoint that `amuxd init` POSTs the anonymous
# /v1/invites/claim request to. There is NO default — provider_config.rs errors
# with "Cloud API URL not configured" when this is unset.
# TEAMCLAW_CLOUD_API_URL=https://api.teamclaw-dev.ucar.cc
