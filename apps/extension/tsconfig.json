{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "types": ["chrome", "vitest/globals"],
    "skipLibCheck": true,
    "paths": {
      "@teamclaw/extension-link-hover": ["../../packages/app/src/lib/extension-link-hover/index.ts"],
      "@teamclaw/extension-link-hover/*": ["../../packages/app/src/lib/extension-link-hover/*"],
      "@teamclaw/extension-link-session": ["../../packages/app/src/lib/extension-link-session/index.ts"],
      "@teamclaw/extension-link-session/*": ["../../packages/app/src/lib/extension-link-session/*"]
    }
  },
  "include": ["src", "build.mjs"]
}
