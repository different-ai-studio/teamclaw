# teamclaw-fc — environment template for Docker self-host.
# Copy to .env and fill in. The full authoritative list lives in s.yaml.

# --- container-specific ---
PORT=9000
HOST=0.0.0.0
CRON_TRIGGER_SECRET=
BACKEND_KIND=supabase

# --- core (see s.yaml for the complete set) ---
SUPABASE_URL=
SUPABASE_PUBLIC_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# DATABASE_URL / POSTGRES_* for the postgres backend
DATABASE_URL=

# --- OSS / object storage ---
ACCESS_KEY_ID=
ACCESS_KEY_SECRET=
ROLE_ARN=
BUCKET=teamclaw-team
REGION=cn-shenzhen
ENDPOINT=https://oss-cn-shenzhen.aliyuncs.com

# --- MQTT ---
MQTT_BROKER_URL=

# --- LiteLLM (optional) ---
LITELLM_URL=
LITELLM_MASTER_KEY=
